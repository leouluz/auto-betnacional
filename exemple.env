BOT_TOKEN= token do bot
CHAT_ID= id do grupo para onde as mensagens seram enviadas
HOME_CHAT_ID= id do grupo que quero replicar as mensagens
TELEGRAM_URL=https://web.telegram.org/k/

caminho de instalacao do navegador que esta utilizando
EDGE_EXECUTABLE_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
EDGE_USER_DATA_DIR =C:\Users\user\AppData\Local\Google\Chrome\User Data\Profile 1


API de envio de mensagens utilizando telegram pessoal
TELEGRAM_API_ID=  # ID da API gerada em https://my.telegram.org
TELEGRAM_API_HASH= # Hash gerado no mesmo lugar
TELEGRAM_SESSION_NAME=user_session
TELEGRAM_USER_CHAT_ID= id do grupo que quero enviar mensagens usando usuario
TELEGRAM_SESSION_STRING= sesao gerada pelo arquivo sessao.js

